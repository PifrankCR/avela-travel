---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "TouristInformationCenter",
  "name": "Avela Travel",
  "description": "Luxury travel concierge focused exclusively on Nosara, Costa Rica.",
  "url": "https://avela.travel",
  "areaServed": {
    "@type": "City",
    "name": "Nosara",
    "addressCountry": "CR"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Nosara Travel Experiences",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "LodgingBusiness", "name": "Luxury Villas" } },
      { "@type": "Offer", "itemOffered": { "@type": "FoodEstablishment", "name": "Private Chefs" } },
      { "@type": "Offer", "itemOffered": { "@type": "SportsActivityLocation", "name": "Surf Sessions" } }
    ]
  }
};
---

<BaseLayout
  title="Avela Travel | Luxury Concierge in Nosara, Costa Rica"
  description="Avela curates your entire Nosara experience — handpicked luxury villas, private chefs, surf sessions, ocean adventures, and complete itinerary planning."
  schema={schema}
>

  <!-- ─── HERO ─── -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <img
        src="/images/zenith/DSC04764-HDR.jpg"
        alt="Villa Zenith — panoramic ocean view, Nosara Costa Rica"
        class="hero-img"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <p class="eyebrow hero-eyebrow">Nosara, Costa Rica</p>
      <h1 class="hero-h1">
        Blue Zone Spirit.<br />
        <em>Costa Rica Soul.</em>
      </h1>
      <p class="hero-sub">
        Avela curates your entire Nosara experience — from a handpicked luxury villa to private chefs,
        surf lessons, jungle tours, and everything in between.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn-primary">Plan My Trip</a>
        <a href="/villas" class="btn-ghost">Browse Villas</a>
      </div>
    </div>

    <a href="#intro" class="hero-scroll" aria-label="Scroll down">
      <span class="hero-scroll-line"></span>
    </a>
  </section>

  <!-- ─── INTRO ─── -->
  <section class="section intro" id="intro">
    <div class="section-inner intro-inner">
      <div class="intro-text reveal">
        <p class="eyebrow">Where the jungle meets the sea</p>
        <h2>
          There is a place on Costa Rica's Pacific coast where nature moves at its own pace
          and life feels genuinely unhurried.
        </h2>
        <p>
          Nosara sits inside one of the world's five Blue Zones — places where people live
          longest, thrive most fully, and stay connected to what matters. We built Avela so
          every guest arrives knowing exactly where to go, who to trust, and how to spend
          each day in a way that feels true to this place.
        </p>
        <p>
          We are not a booking platform. We are a local team that knows every villa, every
          chef, every boat captain, and every trail — and we have every reason to make your
          experience extraordinary.
        </p>
      </div>
      <div class="intro-stats reveal reveal-delay-2">
        <div class="stat-card">
          <span class="stat-num">100%</span>
          <span class="stat-label">Nosara focus — every recommendation is local and vetted</span>
        </div>
        <div class="stat-card accent">
          <span class="stat-num">7</span>
          <span class="stat-label">Categories of experiences — one point of contact for all</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">24/7</span>
          <span class="stat-label">On-the-ground support for concierge clients</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">2</span>
          <span class="stat-label">Private boats for ocean adventures and sunset cruises</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TWO PATHS ─── -->
  <section class="section paths" id="paths" style="background: var(--sand);">
    <div class="section-inner">
      <p class="eyebrow paths-eyebrow reveal">Two ways to experience Nosara</p>
      <h2 class="paths-h2 reveal reveal-delay-1">How would you like to travel?</h2>
      <div class="paths-grid">
        <div class="path-card reveal reveal-delay-2">
          <div class="path-num">01</div>
          <h3>Book Your Way</h3>
          <p class="path-desc">
            Browse our handpicked villa collection, add tours and ocean adventures,
            arrange airport transport, and build your stay piece by piece. Everything
            is vetted — you simply choose what you want.
          </p>
          <ul class="path-list">
            <li>Villa rentals</li>
            <li>Individual tours</li>
            <li>Ocean adventures</li>
            <li>Vehicle rentals</li>
          </ul>
          <a href="/villas" class="path-cta">Browse Villas</a>
        </div>

        <div class="path-card path-card-featured reveal reveal-delay-3">
          <div class="path-num">02</div>
          <div class="path-badge">Most popular</div>
          <h3>Avela Experience</h3>
          <p class="path-desc">
            Tell us your dates, group size, and what you care about most. We handle
            everything — villa selection, private chef scheduling, daily activities,
            airport transfers, and any request that comes up during your stay.
          </p>
          <ul class="path-list">
            <li>Custom itinerary planning</li>
            <li>Private chef + villa bundled</li>
            <li>24/7 on-the-ground support</li>
            <li>One point of contact for all</li>
          </ul>
          <a href="/contact" class="path-cta path-cta-featured">Plan My Trip</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICES ─── -->
  <section class="section services" id="services" style="background: var(--green-deep);">
    <div class="section-inner">
      <div class="services-header reveal">
        <p class="eyebrow">Everything in one place</p>
        <h2 class="services-h2">
          Seven ways to make your<br />
          <em>Nosara stay extraordinary</em>
        </h2>
      </div>
      <div class="services-grid">
        {[
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>`,
            name: 'Luxury Villas',
            desc: 'Handpicked, locally vetted homes with pools, jungle or ocean views, and full concierge-ready amenities.',
            delay: 1,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
            name: 'Private Chefs',
            desc: 'Farm-to-table meals prepared in your villa — Costa Rican ingredients, international technique, and zero restaurant waits.',
            delay: 2,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
            name: 'Surf Sessions',
            desc: 'Playa Guiones breaks suit every level. Our instructors know the tides, the crowds, and how to get you standing.',
            delay: 3,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
            name: 'Ocean Adventures',
            desc: 'Monkey Head Adventures runs two private boats. Snorkeling, sportfishing, sunset cruises — the Pacific at your pace.',
            delay: 4,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.34A1 1 0 004.66 21 16.46 16.46 0 0018 10"/><path d="M17 8l3-3M12 3l-1 5M7 8l3 1"/></svg>`,
            name: 'Jungle Adventures',
            desc: 'ATV rides through the canopy, waterfall hikes, wildlife encounters, and zip-lining across the Nicoya ridge.',
            delay: 5,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
            name: 'Transport',
            desc: 'Airport transfers from SJO or LIR, 4x4 rentals for the dry season roads, and private drivers for full-day trips.',
            delay: 6,
          },
          {
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
            name: 'Wellness',
            desc: 'In-villa spa treatments, morning yoga, sound healing sessions, and Blue Zone retreats rooted in Nosara tradition.',
            delay: 7,
          },
        ].map(({ icon, name, desc, delay }) => (
          <div class={`service-card reveal reveal-delay-${delay}`}>
            <div class="service-icon" set:html={icon}></div>
            <h3>{name}</h3>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── VILLAS ─── -->
  <section class="section" id="villas">
    <div class="section-inner">
      <div class="villas-header reveal">
        <p class="eyebrow">Featured properties</p>
        <h2>
          Two villas, two worlds —<br />
          <em>both extraordinary</em>
        </h2>
      </div>

      <!-- Villa Ocaso -->
      <div class="villa-feature reveal">
        <div class="villa-gallery">
          <div class="villa-main-img">
            <img
              src="/images/ocaso/ocaso-1.jpg"
              alt="Villa Ocaso — floor-to-ceiling jungle glass walls"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="villa-thumbs">
            <img src="/images/ocaso/ocaso-2.jpg" alt="Villa Ocaso open-plan living and kitchen" loading="lazy" />
            <img src="/images/ocaso/ocaso-3.jpg" alt="Villa Ocaso master bedroom" loading="lazy" />
            <img src="/images/ocaso/ocaso-4.jpg" alt="Villa Ocaso second bedroom" loading="lazy" />
            <img src="/images/ocaso/ocaso-5.jpg" alt="Villa Ocaso living room alternate" loading="lazy" />
          </div>
        </div>
        <div class="villa-info">
          <p class="eyebrow">Villa Ocaso</p>
          <h3>Where the jungle becomes your walls</h3>
          <p>
            Floor-to-ceiling glass opens Villa Ocaso entirely to the surrounding jungle canopy.
            Natural wood finishes, a private pool, and four bedrooms sleeping ten — designed
            for families and groups who want total immersion in Costa Rica's biodiversity
            without sacrificing comfort.
          </p>
          <div class="villa-specs">
            <span><strong>4</strong> bedrooms</span>
            <span><strong>10</strong> guests</span>
            <span>Private pool</span>
            <span>Jungle setting</span>
          </div>
          <div class="villa-actions">
            <a href="/villas#ocaso" class="btn-primary">View Villa</a>
            <a href="/contact" class="btn-outline">Inquire</a>
          </div>
        </div>
      </div>

      <!-- Villa Zenith -->
      <div class="villa-feature villa-feature-reverse reveal">
        <div class="villa-gallery">
          <div class="villa-main-img">
            <img
              src="/images/zenith/DSC04803-HDR.jpg"
              alt="Villa Zenith — panoramic ocean view terrace"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="villa-thumbs">
            <img src="/images/zenith/DSC04551.jpg" alt="Villa Zenith outdoor lounge" loading="lazy" />
            <img src="/images/zenith/DSC04746-HDR.jpg" alt="Villa Zenith dining with pendant lights" loading="lazy" />
            <img src="/images/zenith/DSC04785-HDR.jpg" alt="Villa Zenith BBQ terrace" loading="lazy" />
            <img src="/images/zenith/DSC04956-HDR-Edit.jpg" alt="Villa Zenith interior" loading="lazy" />
          </div>
        </div>
        <div class="villa-info">
          <p class="eyebrow">Villa Zenith</p>
          <h3>The Pacific from every angle</h3>
          <p>
            Perched on the hillside above Nosara, Villa Zenith commands a panoramic sweep
            of the Pacific. Five bedrooms, stone and wood architecture, an outdoor BBQ terrace,
            designer interiors, and a chef kitchen built for entertaining. The kind of villa
            that defines a trip for years.
          </p>
          <div class="villa-specs">
            <span><strong>5</strong> bedrooms</span>
            <span><strong>12</strong> guests</span>
            <span>Ocean views</span>
            <span>Chef kitchen</span>
          </div>
          <div class="villa-actions">
            <a href="/villas#zenith" class="btn-primary">View Villa</a>
            <a href="/contact" class="btn-outline">Inquire</a>
          </div>
        </div>
      </div>

      <div class="villas-all reveal">
        <a href="/villas" class="btn-outline-dark">View All Villas</a>
      </div>
    </div>
  </section>

  <!-- ─── TESTIMONIAL ─── -->
  <section class="testimonial reveal" style="background: var(--dark);">
    <div class="testimonial-inner">
      <svg class="testimonial-quote" viewBox="0 0 60 48" fill="none" aria-hidden="true">
        <path d="M0 48V29.4C0 13.2 9.4 4.2 28.2 2l2.4 4.8C20.4 9 15.4 14.6 14.4 24H26.4V48H0ZM33.6 48V29.4C33.6 13.2 43 4.2 61.8 2L64.2 6.8C53.8 9 48.8 14.6 48 24H60V48H33.6Z" fill="currentColor"/>
      </svg>
      <blockquote>
        We handed Avela our dates and said do whatever you think is best.
        What followed was the best family vacation we have ever taken.
        Every detail was right — the villa, the chef, the surf instructor who
        got our ten-year-old standing on day one.
      </blockquote>
      <cite>
        <strong>Sarah &amp; Tom K.</strong>
        <span>Family of five, visited February 2025</span>
      </cite>
    </div>
  </section>

  <!-- ─── CTA BAND ─── -->
  <section class="cta-band">
    <div class="cta-band-bg">
      <img
        src="/images/zenith/DSC04863-HDR.jpg"
        alt="Nosara sunset over the Pacific"
        loading="lazy"
        decoding="async"
      />
      <div class="cta-band-overlay"></div>
    </div>
    <div class="cta-band-content reveal">
      <p class="eyebrow">Ready when you are</p>
      <h2>Your Nosara story starts here.</h2>
      <p>Tell us your dates and we will take it from there.</p>
      <div class="cta-band-actions">
        <a href="/contact" class="btn-primary">Plan My Trip</a>
        <a href="/villas" class="btn-ghost">Browse Villas</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── Hero ─── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(19, 18, 16, 0.45) 0%,
      rgba(19, 18, 16, 0.3) 50%,
      rgba(19, 18, 16, 0.6) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 760px;
    padding: 0 var(--gutter);
  }

  .hero-eyebrow {
    margin-bottom: 1.25rem;
  }

  .hero-h1 {
    font-size: clamp(3rem, 7vw, 6rem);
    color: var(--warm-cream);
    margin-bottom: 1.5rem;
    line-height: 1.05;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--amber);
  }

  .hero-sub {
    font-size: clamp(15px, 2vw, 18px);
    font-weight: 300;
    color: rgba(255, 241, 207, 0.7);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255, 241, 207, 0.6), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { opacity: 0.6; transform: scaleY(1); transform-origin: top; }
    50% { opacity: 1; }
  }

  /* ─── Buttons ─── */
  .btn-primary {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 16px 36px;
    background: var(--amber);
    color: var(--cream);
    transition: background 0.3s;
  }

  .btn-primary:hover {
    background: var(--amber-deep);
  }

  .btn-ghost {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 15px 36px;
    border: 1px solid rgba(255, 241, 207, 0.4);
    color: var(--warm-cream);
    transition: all 0.3s;
  }

  .btn-ghost:hover {
    border-color: var(--warm-cream);
    background: rgba(255, 241, 207, 0.08);
  }

  .btn-outline {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 15px 36px;
    border: 1px solid var(--green-deep);
    color: var(--green-deep);
    transition: all 0.3s;
  }

  .btn-outline:hover {
    background: var(--green-deep);
    color: var(--cream);
  }

  .btn-outline-dark {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 15px 48px;
    border: 1px solid var(--dark);
    color: var(--dark);
    transition: all 0.3s;
  }

  .btn-outline-dark:hover {
    background: var(--dark);
    color: var(--cream);
  }

  /* ─── Intro ─── */
  .intro-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .intro-text .eyebrow {
    margin-bottom: 1.5rem;
  }

  .intro-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--green-deep);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .intro-text p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(19, 18, 16, 0.65);
    margin-bottom: 1rem;
  }

  .intro-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    padding: 2rem 1.5rem;
    background: var(--sand);
    border: 1px solid rgba(58, 79, 65, 0.1);
  }

  .stat-card.accent {
    background: var(--green-deep);
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--green-deep);
    display: block;
    margin-bottom: 0.5rem;
  }

  .stat-card.accent .stat-num {
    color: var(--amber);
  }

  .stat-label {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(19, 18, 16, 0.55);
  }

  .stat-card.accent .stat-label {
    color: rgba(255, 241, 207, 0.6);
  }

  /* ─── Paths ─── */
  .paths-eyebrow {
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .paths-h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    color: var(--green-deep);
    text-align: center;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .paths-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .path-card {
    background: var(--cream);
    padding: clamp(2rem, 4vw, 3rem);
    border: 1px solid rgba(58, 79, 65, 0.1);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .path-card-featured {
    background: var(--green-deep);
  }

  .path-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(58, 79, 65, 0.12);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .path-card-featured .path-num {
    color: rgba(255, 241, 207, 0.12);
  }

  .path-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--amber);
    color: var(--cream);
    padding: 4px 10px;
  }

  .path-card h3 {
    font-size: 1.6rem;
    color: var(--green-deep);
    margin-bottom: 1rem;
  }

  .path-card-featured h3 {
    color: var(--warm-cream);
  }

  .path-desc {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(19, 18, 16, 0.65);
    margin-bottom: 1.5rem;
  }

  .path-card-featured .path-desc {
    color: rgba(255, 241, 207, 0.6);
  }

  .path-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex: 1;
  }

  .path-list li {
    font-size: 14px;
    font-weight: 400;
    color: rgba(19, 18, 16, 0.7);
    padding-left: 1.25rem;
    position: relative;
  }

  .path-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
  }

  .path-card-featured .path-list li {
    color: rgba(255, 241, 207, 0.7);
  }

  .path-cta {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 14px 32px;
    border: 1px solid var(--green-deep);
    color: var(--green-deep);
    transition: all 0.3s;
    align-self: flex-start;
  }

  .path-cta:hover {
    background: var(--green-deep);
    color: var(--cream);
  }

