---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder guides — each entry should later have a /guides/<slug>.astro detail page.
const guides = [
  {
    slug: 'getting-to-nosara',
    category: 'Logistics',
    title: 'Getting to Nosara',
    duration: '5 min read',
    excerpt:
      'Liberia vs. San Jose, the Sansa shortcut, road conditions, and the smartest way to land at your villa.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 12h20M12 2a15 15 0 014 10 15 15 0 01-4 10 15 15 0 01-4-10 15 15 0 014-10z"/><circle cx="12" cy="12" r="10"/></svg>`,
  },
  {
    slug: 'when-to-visit',
    category: 'Seasons',
    title: 'When to visit Nosara',
    duration: '6 min read',
    excerpt:
      'Dry season versus green season, surf swell windows, holiday surcharges, and the two weeks of the year locals consider the secret peak.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>`,
  },
  {
    slug: 'surf-in-nosara',
    category: 'Activities',
    title: 'Surfing Nosara',
    duration: '7 min read',
    excerpt:
      'Why Playa Guiones suits every level, when to surf Pelada, board choice for beginners, and how to read a Costa Rica swell forecast.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 16c2 0 3-2 5-2s3 2 5 2 3-2 5-2 3 2 5 2"/><path d="M2 10c2 0 3-2 5-2s3 2 5 2 3-2 5-2 3 2 5 2"/></svg>`,
  },
  {
    slug: 'eating-in-nosara',
    category: 'Food',
    title: 'Eating in Nosara',
    duration: '8 min read',
    excerpt:
      'The restaurants we book repeat clients into, the local markets that matter, and the chefs who cook in your villa.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 11h18M5 11V7a7 7 0 0114 0v4M5 11v6a3 3 0 003 3h8a3 3 0 003-3v-6"/></svg>`,
  },
  {
    slug: 'what-to-pack',
    category: 'Logistics',
    title: 'What to pack',
    duration: '4 min read',
    excerpt:
      'A short list that holds up across seasons. Reef-safe sunscreen, a single dressy outfit, and the one thing nobody brings but always needs.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>`,
  },
  {
    slug: 'with-kids',
    category: 'Family',
    title: 'Nosara with kids',
    duration: '6 min read',
    excerpt:
      'Surf lessons that actually work for six-year-olds, the boat trip that does not get rough, and the chef who knows kid menus.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="7" r="3"/><path d="M5 21v-2a4 4 0 014-4h6a4 4 0 014 4v2"/><circle cx="6.5" cy="11" r="1.5"/><circle cx="17.5" cy="11" r="1.5"/></svg>`,
  },
  {
    slug: 'the-blue-zone',
    category: 'Place',
    title: 'Why Nosara is a Blue Zone',
    duration: '7 min read',
    excerpt:
      'The Nicoya Peninsula is one of five places on Earth where people live longest. Here is what that means in practice — and why it changes how you feel after a week here.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    slug: 'wellness-in-nosara',
    category: 'Wellness',
    title: 'Wellness in Nosara',
    duration: '6 min read',
    excerpt:
      'Yoga shalas, sound healing, in-villa massage, ice baths, and plant medicine. Who is reputable, what is overhyped, and how to design a healing week.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 18c0-5 2-9 6-9s6 4 6 9"/><path d="M12 9v-6M9 5l3-2 3 2"/></svg>`,
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Avela Travel Guides',
  description: 'Practical guides to Nosara, Costa Rica: getting here, when to visit, surf, food, wellness, and family travel.',
  url: 'https://avela.travel/guides',
};
---

<BaseLayout
  title="Guides | Avela Travel — Nosara, Costa Rica"
  description="Practical guides to Nosara: how to get here, when to visit, surf seasons, food, family travel, and wellness. Written by our team on the ground."
  schema={pageSchema}
>
  <!-- ─── HERO ─── -->
  <section class="guides-hero">
    <div class="guides-hero-inner">
      <p class="eyebrow">Guides</p>
      <h1>
        Everything you need to <em>know about Nosara</em>
      </h1>
      <p class="hero-lede">
        The questions we answer most often, written down. Practical, opinionated, and updated
        from the ground. No filler.
      </p>
    </div>
  </section>

  <!-- ─── GUIDES GRID ─── -->
  <section class="guides-grid-section">
    <div class="guides-grid-inner">
      <div class="guides-grid">
        {guides.map((g, i) => (
          <article class="guide-card reveal" style={`--delay:${i * 60}ms`}>
            <a href={`/guides/${g.slug}`} class="guide-card-link" aria-label={g.title}>
              <div class="guide-card-icon" set:html={g.icon}></div>
              <div class="guide-card-body">
                <p class="guide-card-cat">{g.category} · {g.duration}</p>
                <h2>{g.title}</h2>
                <p class="guide-card-excerpt">{g.excerpt}</p>
                <span class="guide-card-arrow">Read guide →</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <p class="guides-footer-note">
        Missing a topic you wanted answered? <a href="/contact">Send us the question</a> —
        we will add it to the queue.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── HERO ─── */
  .guides-hero {
    background: var(--green-deep);
    color: var(--warm-cream);
    padding: clamp(140px, 16vw, 200px) var(--gutter) clamp(60px, 9vw, 110px);
    text-align: center;
  }

  .guides-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .guides-hero .eyebrow {
    color: var(--amber);
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .guides-hero h1 {
    font-size: clamp(46px, 6.5vw, 92px);
    line-height: 1.02;
    margin-bottom: 2rem;
  }

  .guides-hero h1 em {
    font-style: italic;
    color: var(--amber);
  }

  .hero-lede {
    font-size: clamp(16px, 1.7vw, 20px);
    line-height: 1.7;
    color: rgba(255, 241, 207, 0.78);
  }

  /* ─── GRID ─── */
  .guides-grid-section {
    background: var(--cream);
    padding: clamp(80px, 12vw, 140px) var(--gutter);
  }

  .guides-grid-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .guide-card {
    background: var(--cream);
    border: 1px solid rgba(19, 18, 16, 0.1);
    transition-delay: var(--delay, 0ms);
    transition: border-color 0.25s var(--ease-smooth), background 0.25s var(--ease-smooth);
  }

  .guide-card:hover {
    border-color: var(--brown);
    background: rgba(184, 116, 42, 0.04);
  }

  .guide-card-link {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.5rem;
    padding: 1.75rem 1.85rem;
    align-items: start;
  }

  .guide-card-icon {
    width: 44px;
    height: 44px;
    color: var(--brown);
    flex-shrink: 0;
  }

  .guide-card-icon svg {
    width: 100%;
    height: 100%;
  }

  .guide-card-cat {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brown);
    margin: 0 0 0.6rem;
  }

  .guide-card h2 {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.18;
    margin: 0 0 0.75rem;
    color: var(--dark);
  }

  .guide-card-excerpt {
    font-size: 14.5px;
    line-height: 1.6;
    color: rgba(19, 18, 16, 0.72);
    margin: 0 0 1rem;
  }

  .guide-card-arrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.45);
  }

  .guide-card:hover .guide-card-arrow {
    color: var(--brown);
  }

  .guides-footer-note {
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(15px, 1.5vw, 18px);
    color: rgba(19, 18, 16, 0.6);
    margin: 0;
  }

  .guides-footer-note a {
    color: var(--brown);
    border-bottom: 1px solid currentColor;
  }

  @media (max-width: 720px) {
    .guides-grid {
      grid-template-columns: 1fr;
    }
    .guide-card-link {
      grid-template-columns: 48px 1fr;
      gap: 1.25rem;
      padding: 1.5rem;
    }
  }
</style>
