---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureIcon from '../../components/FeatureIcon.astro';
import { villas } from '../../data/alba-villas';

export function getStaticPaths() {
  return villas.map((villa) => ({
    params: { slug: villa.slug },
    props: { villa },
  }));
}

const { villa } = Astro.props;

// JSON-LD structured data for Google — LodgingBusiness schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: `${villa.name}, Luxury Villa in Nosara, Costa Rica`,
  description: villa.shortDescription,
  image: villa.gallery.map((p) => `https://avela.travel${p.src}`),
  numberOfRooms: villa.bedrooms,
  petsAllowed: false,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Nosara',
    addressRegion: 'Guanacaste',
    addressCountry: 'CR',
  },
  amenityFeature: villa.amenities.map((a) => ({
    '@type': 'LocationFeatureSpecification',
    name: a,
    value: true,
  })),
  url: `https://avela.travel/villas/${villa.slug}`,
};
---

<BaseLayout
  title={`${villa.name} · ${villa.tagline} | Avela Travel Nosara`}
  description={villa.shortDescription}
  image={villa.cover.src}
  schema={schema}
>
  <!-- Page header -->
  <div class="page-header">
    <div class="page-header-inner">
      <p class="eyebrow reveal">{villa.eyebrow} · {villa.area}</p>
      <h1 class="reveal reveal-delay-1">
        {villa.name}<br />
        <em>{villa.tagline}</em>
      </h1>
      <p class="page-subtitle reveal reveal-delay-2">{villa.shortDescription}</p>
    </div>
  </div>

  <section class="villa-detail section">
    <div class="section-inner">
      <div class="villa-detail-header reveal">
        <div class="villa-detail-meta">
          <div class="meta-item">
            <span class="meta-num">{villa.bedrooms}</span>
            <span class="meta-label">Bedrooms</span>
          </div>
          <div class="meta-item">
            <span class="meta-num">{villa.bathrooms}</span>
            <span class="meta-label">Bathrooms</span>
          </div>
          <div class="meta-item">
            <span class="meta-num">{villa.guests}</span>
            <span class="meta-label">Guests</span>
          </div>
          {villa.features.map((f) => (
            <div class="meta-item meta-item-icon">
              <FeatureIcon label={f} />
              <span class="meta-label">{f}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="villa-gallery-full reveal">
        <div class="gallery-main" id={`${villa.slug}-main`}>
          <img
            src={villa.gallery[0]!.src}
            alt={villa.gallery[0]!.alt}
            class="gallery-main-img"
            width="1600"
            height="1067"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <div class="gallery-strip">
          {villa.gallery.map((photo, i) => (
            <button
              class={`gallery-thumb ${i === 0 ? 'active' : ''}`}
              data-gallery={villa.slug}
              data-src={photo.src}
              data-alt={photo.alt}
              aria-label={photo.alt}
              type="button"
            >
              <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" width="400" height="267" />
            </button>
          ))}
        </div>
      </div>

      <div class="villa-detail-body">
        <div class="villa-detail-text reveal">
          <h2>About {villa.name}</h2>
          {villa.longDescription.map((p) => <p>{p}</p>)}

          <h3>Amenities & features</h3>
          <ul class="villa-features">
            {villa.amenities.map((a) => <li>{a}</li>)}
          </ul>
        </div>

        <div class="villa-detail-cta reveal reveal-delay-2">
          <div class="inquiry-card">
            <p class="eyebrow">Request availability</p>
            <h4>{villa.name}</h4>
            <p class="inquiry-note">
              Rates vary by season and group size. Send us your dates for a personalized quote and full property briefing.
            </p>
            <a href={`/contact?villa=${villa.slug}`} class="btn-cta">Inquire Now</a>
            <div class="inquiry-or">
              <span>or reach us directly on</span>
            </div>
            <a
              href="https://wa.me/50687297620"
              class="whatsapp-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp us
            </a>
            <a href="/villas" class="back-link">← Back to all villas</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="concierge-band-full section" style="background: var(--green-deep);">
    <div class="section-inner concierge-inner reveal">
      <div class="concierge-copy">
        <p class="eyebrow">Go further</p>
        <h2>Add the full Avela experience</h2>
        <p>
          Book {villa.name} and let us build everything around it: private chef, daily
          activities, airport transfers, and 24/7 support from our local team in Nosara.
        </p>
      </div>
      <div class="concierge-actions">
        <a href="/contact" class="btn-cream">Plan My Trip</a>
        <a href="/villas" class="btn-cream-ghost">All Villas</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: var(--dark);
    padding: 160px var(--gutter) clamp(60px, 8vw, 100px);
  }
  .page-header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .page-header .eyebrow { margin-bottom: 1.25rem; }
  .page-header h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--warm-cream);
    margin-bottom: 1.5rem;
    line-height: 1.05;
  }
  .page-header h1 em { font-style: italic; color: var(--amber); }
  .page-subtitle {
    font-size: clamp(15px, 2vw, 17px);
    font-weight: 300;
    color: rgba(255, 241, 207, 0.6);
    max-width: 720px;
    line-height: 1.7;
  }

  .villa-detail-header {
    margin-bottom: 2.5rem;
  }
  .villa-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
  }
  .meta-item { display: flex; flex-direction: column; gap: 0.25rem; align-items: flex-start; }
  .meta-item-icon { gap: 0.5rem; align-items: flex-start; }
  .meta-item-icon .feature-icon { width: 32px; height: 32px; }
  .meta-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    color: var(--green-deep);
  }
  .meta-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.55);
  }

  .villa-gallery-full {
    margin-bottom: 4rem;
  }
  .gallery-main {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--dark);
  }
  .gallery-main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s;
  }
  .gallery-strip {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  @media (max-width: 700px) {
    .gallery-strip { grid-template-columns: repeat(4, 1fr); }
  }
  .gallery-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--dark);
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.3s;
  }
  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gallery-thumb.active { border-color: var(--amber); }

  .villa-detail-body {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
  }
  @media (max-width: 900px) {
    .villa-detail-body { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .villa-detail-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
    color: var(--green-deep);
  }
  .villa-detail-text h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--green-deep);
  }
  .villa-detail-text p {
    margin-bottom: 1rem;
    font-size: 16px;
    line-height: 1.75;
    color: rgba(19, 18, 16, 0.78);
  }
  .villa-features {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.5rem 1.5rem;
  }
  .villa-features li {
    padding-left: 1.25rem;
    position: relative;
    font-size: 14px;
    color: rgba(19, 18, 16, 0.7);
  }
  .villa-features li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--amber);
  }

  .villa-detail-cta { position: relative; }
  .inquiry-card {
    background: var(--warm-cream);
    border: 1px solid rgba(19, 18, 16, 0.08);
    padding: 2.5rem 2rem;
    position: sticky;
    top: 100px;
  }
  .inquiry-card .eyebrow { margin-bottom: 0.5rem; }
  .inquiry-card h4 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--green-deep);
  }
  .inquiry-note {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(19, 18, 16, 0.65);
    margin-bottom: 1.5rem;
  }
  .btn-cta {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px 20px;
    background: var(--green-deep);
    color: var(--warm-cream);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: background 0.3s;
  }
  .btn-cta:hover { background: var(--dark); }
  .inquiry-or {
    text-align: center;
    margin: 1.25rem 0 1rem;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.45);
  }
  .whatsapp-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 12px;
    border: 1px solid rgba(19, 18, 16, 0.15);
    color: var(--green-deep);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .whatsapp-link:hover {
    background: var(--green-deep);
    color: var(--warm-cream);
    border-color: var(--green-deep);
  }
  .whatsapp-link svg { width: 16px; height: 16px; }
  .back-link {
    display: block;
    text-align: center;
    margin-top: 1.5rem;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.55);
  }
  .back-link:hover { color: var(--green-deep); }

  .concierge-band-full { padding: 5rem var(--gutter); }
  .concierge-inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 800px) {
    .concierge-inner { grid-template-columns: 1fr; }
  }
  .concierge-copy h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    color: var(--warm-cream);
    margin-bottom: 1rem;
  }
  .concierge-copy p {
    color: rgba(255, 241, 207, 0.7);
    font-size: 15px;
    line-height: 1.7;
    max-width: 560px;
  }
  .concierge-actions { display: flex; flex-direction: column; gap: 0.75rem; }
  .btn-cream, .btn-cream-ghost {
    display: inline-block;
    text-align: center;
    padding: 14px 28px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.3s;
  }
  .btn-cream { background: var(--warm-cream); color: var(--green-deep); }
  .btn-cream:hover { background: var(--amber); color: var(--cream); }
  .btn-cream-ghost {
    border: 1px solid rgba(255, 241, 207, 0.3);
    color: var(--warm-cream);
  }
  .btn-cream-ghost:hover { background: var(--warm-cream); color: var(--green-deep); }
</style>

<script>
  document.querySelectorAll('.gallery-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const gallery = (btn as HTMLElement).dataset.gallery;
      const src = (btn as HTMLElement).dataset.src;
      const alt = (btn as HTMLElement).dataset.alt;
      if (!gallery || !src) return;
      const mainImg = document.querySelector<HTMLImageElement>(`#${gallery}-main .gallery-main-img`);
      if (!mainImg) return;
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = src;
        if (alt) mainImg.alt = alt;
        mainImg.style.opacity = '1';
      }, 200);
      document.querySelectorAll(`.gallery-thumb[data-gallery="${gallery}"]`).forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>
