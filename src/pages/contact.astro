---
import BaseLayout from '../layouts/BaseLayout.astro';

const villa = Astro.url.searchParams.get('villa') ?? '';
---

<BaseLayout
  title="Plan Your Nosara Trip | Avela Travel"
  description="Tell us your dates, group size, and what you are after. We will handle the rest: villas, chefs, activities, transport, and everything in between."
>

  <div class="page-header">
    <div class="page-header-inner">
      <p class="eyebrow reveal">Get in touch</p>
      <h1 class="reveal reveal-delay-1">
        Let's plan<br />
        <em>your Nosara trip</em>
      </h1>
      <p class="page-subtitle reveal reveal-delay-2">
        Fill in what you know. We will get back to you within 24 hours with
        villa options, availability, and a rough itinerary. No commitment required.
      </p>
    </div>
  </div>

  <section class="section contact-section">
    <div class="section-inner contact-inner">

      <div class="contact-form-wrap reveal">
        <form
          class="contact-form"
          action="https://formspree.io/f/xpqbneel"
          method="POST"
          novalidate
          id="contact-form"
        >
          <div class="form-row">
            <div class="form-field">
              <label for="first_name">First name <span aria-hidden="true">*</span></label>
              <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
            </div>
            <div class="form-field">
              <label for="last_name">Last name <span aria-hidden="true">*</span></label>
              <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
            </div>
          </div>

          <div class="form-field">
            <label for="email">Email address <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>

          <div class="form-field">
            <label for="phone">Phone / WhatsApp (optional)</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" />
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="arrival">Arrival date <span aria-hidden="true">*</span></label>
              <input type="date" id="arrival" name="arrival" required />
            </div>
            <div class="form-field">
              <label for="departure">Departure date <span aria-hidden="true">*</span></label>
              <input type="date" id="departure" name="departure" required />
            </div>
          </div>

          <div class="form-field">
            <label for="group_size">Group size <span aria-hidden="true">*</span></label>
            <select id="group_size" name="group_size" required>
              <option value="" disabled selected>Select group size</option>
              <option value="2">2 guests</option>
              <option value="3-4">3–4 guests</option>
              <option value="5-6">5–6 guests</option>
              <option value="7-10">7–10 guests</option>
              <option value="11-12">11–12 guests</option>
              <option value="13+">13+ guests</option>
            </select>
          </div>

          <div class="form-field">
            <label for="villa_interest">Villa preference</label>
            <select id="villa_interest" name="villa_interest">
              <option value="" disabled selected={!villa}>No preference, show me options</option>
              <option value="ocaso" selected={villa === 'ocaso'}>Villa Ocaso (Jungle, 4 bed, 10 guests)</option>
              <option value="zenith" selected={villa === 'zenith'}>Villa Zenith (Ocean view, 5 bed, 12 guests)</option>
              <option value="either">Either, best available for my dates</option>
            </select>
          </div>

          <fieldset class="form-fieldset">
            <legend>What are you interested in? <span class="legend-note">(select all that apply)</span></legend>
            <div class="checkbox-grid">
              {[
                { value: 'villa', label: 'Villa rental' },
                { value: 'chef', label: 'Private chef' },
                { value: 'surf', label: 'Surf lessons' },
                { value: 'ocean', label: 'Ocean adventures' },
                { value: 'jungle', label: 'Jungle tours' },
                { value: 'transport', label: 'Transport' },
                { value: 'wellness', label: 'Wellness' },
                { value: 'concierge', label: 'Full concierge' },
              ].map(({ value, label }) => (
                <label class="checkbox-label">
                  <input type="checkbox" name="interests[]" value={value} />
                  <span>{label}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <div class="form-field">
            <label for="message">Anything else we should know?</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Children's ages, dietary needs, special occasions, surf level, preferred activities..."
            ></textarea>
          </div>

          <input type="hidden" name="_subject" value="New Avela Travel inquiry" />
          <input type="text" name="_gotcha" style="display:none" aria-hidden="true" tabindex="-1" />

          <button type="submit" class="form-submit">Send Inquiry</button>

          <p class="form-note">
            We typically reply within 24 hours. For urgent requests, reach us on WhatsApp below.
          </p>
        </form>

        <div class="form-success" id="form-success" aria-live="polite" hidden>
          <p class="eyebrow">Message received</p>
          <h3>Thank you, we will be in touch soon.</h3>
          <p>We typically reply within 24 hours with villa options and a rough itinerary.</p>
          <a href="/" class="btn-back">Back to homepage</a>
        </div>
      </div>

      <aside class="contact-aside reveal reveal-delay-2">
        <div class="aside-section">
          <h3>Prefer to message directly?</h3>
          <a
            href="https://wa.me/50687297620"
            class="whatsapp-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat on WhatsApp
          </a>
          <p class="aside-note">Fastest response for urgent or time-sensitive inquiries.</p>
        </div>

        <div class="aside-section">
          <h3>What happens next?</h3>
          <ol class="next-steps">
            <li>
              <span class="step-num">1</span>
              <div>
                <strong>We review your inquiry</strong>
                <p>Usually within a few hours during business hours (GMT-6).</p>
              </div>
            </li>
            <li>
              <span class="step-num">2</span>
              <div>
                <strong>We send villa options + a rough plan</strong>
                <p>Matched to your dates, group, and interests. No generic templates.</p>
              </div>
            </li>
            <li>
              <span class="step-num">3</span>
              <div>
                <strong>We refine together</strong>
                <p>A short call or message thread to get the details right.</p>
              </div>
            </li>
            <li>
              <span class="step-num">4</span>
              <div>
                <strong>You book and we handle everything</strong>
                <p>From deposit to departure, we are your single point of contact.</p>
              </div>
            </li>
          </ol>
        </div>

        <div class="aside-section aside-villas">
          <h3>Our villas</h3>
          <a href="/villas#ocaso" class="aside-villa-card">
            <img src="/images/ocaso/ocaso-1.jpg" alt="Villa Ocaso" loading="lazy" />
            <div>
              <strong>Villa Ocaso</strong>
              <span>4 bed · 10 guests · Jungle</span>
            </div>
          </a>
          <a href="/villas#zenith" class="aside-villa-card">
            <img src="/images/zenith/DSC04803-HDR.jpg" alt="Villa Zenith" loading="lazy" />
            <div>
              <strong>Villa Zenith</strong>
              <span>5 bed · 12 guests · Ocean view</span>
            </div>
          </a>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    background: var(--dark);
    padding: 160px var(--gutter) clamp(60px, 8vw, 100px);
  }

  .page-header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .page-header .eyebrow {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--warm-cream);
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .page-header h1 em {
    font-style: italic;
    color: var(--amber);
  }

  .page-subtitle {
    font-size: clamp(15px, 2vw, 17px);
    font-weight: 300;
    color: rgba(255, 241, 207, 0.55);
    max-width: 560px;
    line-height: 1.7;
  }

  /* Contact Layout */
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: clamp(3rem, 5vw, 6rem);
    align-items: start;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-field label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.5);
  }

  .form-field label span {
    color: var(--amber);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 300;
    padding: 12px 16px;
    background: var(--cream);
    border: 1px solid rgba(58, 79, 65, 0.18);
    color: var(--dark);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--green-deep);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-fieldset {
    border: 1px solid rgba(58, 79, 65, 0.15);
    padding: 1.5rem;
  }

  .form-fieldset legend {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.5);
    padding: 0 0.5rem;
  }

  .legend-note {
    font-size: 11px;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: rgba(19, 18, 16, 0.35);
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 14px;
    font-weight: 300;
    color: rgba(19, 18, 16, 0.7);
  }

  .checkbox-label input {
    width: 16px;
    height: 16px;
    accent-color: var(--green-deep);
    padding: 0;
    flex-shrink: 0;
  }

  .form-submit {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 18px 40px;
    background: var(--green-deep);
    color: var(--cream);
    transition: background 0.3s;
    align-self: flex-start;
    cursor: pointer;
    border: none;
  }

  .form-submit:hover {
    background: var(--amber);
  }

  .form-note {
    font-size: 13px;
    font-weight: 300;
    color: rgba(19, 18, 16, 0.4);
    line-height: 1.6;
  }

  /* Success state */
  .form-success {
    padding: 3rem;
    background: var(--sand);
    border: 1px solid rgba(58, 79, 65, 0.12);
    text-align: center;
  }

  .form-success .eyebrow {
    margin-bottom: 1rem;
  }

  .form-success h3 {
    font-size: 1.8rem;
    color: var(--green-deep);
    margin-bottom: 0.75rem;
  }

  .form-success p {
    font-size: 15px;
    font-weight: 300;
    color: rgba(19, 18, 16, 0.6);
    margin-bottom: 2rem;
  }

  .btn-back {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 14px 32px;
    border: 1px solid var(--green-deep);
    color: var(--green-deep);
    transition: all 0.3s;
  }

  .btn-back:hover {
    background: var(--green-deep);
    color: var(--cream);
  }

  /* Aside */
  .contact-aside {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .aside-section {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(58, 79, 65, 0.1);
  }

  .aside-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .aside-section h3 {
    font-size: 1.1rem;
    color: var(--green-deep);
    margin-bottom: 1.25rem;
  }

  .whatsapp-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 14px;
    font-weight: 500;
    color: #25D366;
    padding: 12px 20px;
    border: 1px solid rgba(37, 211, 102, 0.3);
    transition: all 0.2s;
    margin-bottom: 0.75rem;
  }

  .whatsapp-btn:hover {
    background: rgba(37, 211, 102, 0.06);
    border-color: #25D366;
  }

  .whatsapp-btn svg {
    width: 22px;
    height: 22px;
  }

  .aside-note {
    font-size: 13px;
    font-weight: 300;
    color: rgba(19, 18, 16, 0.45);
    line-height: 1.6;
  }

  .next-steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .next-steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sand);
    border: 1px solid rgba(58, 79, 65, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 500;
    color: var(--green-deep);
  }

  .next-steps strong {
    font-size: 14px;
    font-weight: 500;
    color: var(--dark);
    display: block;
    margin-bottom: 0.2rem;
  }

  .next-steps p {
    font-size: 13px;
    font-weight: 300;
    color: rgba(19, 18, 16, 0.5);
    line-height: 1.5;
  }

  .aside-villas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .aside-villas h3 {
    margin-bottom: 1rem;
  }

  .aside-villa-card {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.75rem;
    background: var(--sand);
    border: 1px solid rgba(58, 79, 65, 0.1);
    transition: border-color 0.2s;
  }

  .aside-villa-card:hover {
    border-color: var(--green-deep);
  }

  .aside-villa-card img {
    width: 64px;
    height: 48px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .aside-villa-card strong {
    font-size: 14px;
    font-weight: 500;
    color: var(--green-deep);
    display: block;
    margin-bottom: 0.15rem;
  }

  .aside-villa-card span {
    font-size: 12px;
    color: rgba(19, 18, 16, 0.45);
  }

  @media (max-width: 1024px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }

    .contact-aside {
      position: static;
    }
  }

  @media (max-width: 600px) {
    .form-row,
    .checkbox-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const submit = form.querySelector<HTMLButtonElement>('[type="submit"]');
    if (submit) {
      submit.disabled = true;
      submit.textContent = 'Sending...';
    }
    try {
      const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) {
        form.hidden = true;
        if (successMsg) successMsg.hidden = false;
      } else {
        if (submit) { submit.disabled = false; submit.textContent = 'Send Inquiry'; }
        alert('Something went wrong. Please try again or message us on WhatsApp.');
      }
    } catch {
      if (submit) { submit.disabled = false; submit.textContent = 'Send Inquiry'; }
      alert('Something went wrong. Please try again or message us on WhatsApp.');
    }
  });
</script>
