---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder posts — replace with real content as it's published.
// Each entry should later have a corresponding /journal/<slug>.astro page.
const posts = [
  {
    slug: 'a-week-with-the-marx-family',
    category: 'Trip recap',
    title: 'A week with the Marx family',
    date: 'Coming soon',
    excerpt:
      'Eight nights at Raintree with two parents, two kids, and a mix of surfers and yogis. Here is exactly how Stacie built their week — and what she learned along the way.',
    cover: '/images/villas/raintree/01-view-sunset-infinity-pool.jpg',
    coverAlt: 'Sunset view from a luxury villa infinity pool overlooking the jungle, Nosara, Costa Rica',
    author: 'Stacie',
  },
  {
    slug: 'when-to-visit-nosara',
    category: 'Guide',
    title: 'When to actually visit Nosara',
    date: 'Coming soon',
    excerpt:
      'The honest seasonal breakdown — dry season versus green season, surf swell windows, holiday surcharges, and the two weeks of the year that locals consider the secret peak.',
    cover: '/images/experiences/surf.jpg',
    coverAlt: 'Surfer riding a clean Playa Guiones wave, Nosara, Costa Rica',
    author: 'Jordanny',
  },
  {
    slug: 'the-monkey-head-story',
    category: 'Story',
    title: 'How Monkey Head Adventures got two boats',
    date: 'Coming soon',
    excerpt:
      'Our sister company started with one secondhand panga, a lot of bad luck, and an even better story. The full origin of how Garza Harbor became home base.',
    cover: '/images/experiences/ocean.jpg',
    coverAlt: 'Monkey Head Adventures sportfishing boat on the Pacific off Nosara, Costa Rica',
    author: 'Jordanny',
  },
];

const categories = ['All', 'Trip recap', 'Guide', 'Story', 'Press'];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'The Avela Journal',
  description: 'Trip recaps, Nosara guides, and stories from the Avela Experience team.',
  url: 'https://avela.travel/journal',
};
---

<BaseLayout
  title="The Journal | Avela Travel — Nosara, Costa Rica"
  description="Trip recaps, Nosara guides, and stories from the Avela Experience team. Notes from inside a Blue Zone."
  schema={pageSchema}
>
  <!-- ─── HERO ─── -->
  <section class="journal-hero">
    <div class="journal-hero-inner">
      <p class="eyebrow">The Journal</p>
      <h1>
        Field notes from a <em>Blue Zone</em>
      </h1>
      <p class="hero-lede">
        Trip recaps, seasonal guides, partner stories, and the unfiltered local intel
        we share with our guests. New posts as the year unfolds.
      </p>
    </div>
  </section>

  <!-- ─── CATEGORY FILTER ─── -->
  <section class="journal-filter" aria-label="Filter posts by category">
    <div class="journal-filter-inner">
      <ul class="filter-list">
        {categories.map((cat, i) => (
          <li>
            <button
              type="button"
              class={`filter-chip ${i === 0 ? 'active' : ''}`}
              data-filter={cat}
            >
              {cat}
            </button>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ─── POSTS GRID ─── -->
  <section class="journal-grid-section">
    <div class="journal-grid-inner">
      <div class="journal-grid">
        {posts.map((post, i) => (
          <article class="journal-card reveal" style={`--delay:${i * 100}ms`} data-category={post.category}>
            <a href={`#${post.slug}`} class="journal-card-link" aria-label={post.title}>
              <div class="journal-card-image">
                <img
                  src={post.cover}
                  alt={post.coverAlt}
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="600"
                />
                <span class="journal-card-badge">{post.date}</span>
              </div>
              <div class="journal-card-body">
                <p class="journal-card-cat">{post.category} · {post.author}</p>
                <h2>{post.title}</h2>
                <p class="journal-card-excerpt">{post.excerpt}</p>
                <span class="journal-card-arrow">Read note →</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <p class="journal-empty-note">
        More posts in the pipeline. Want them in your inbox?
        Subscribe via the footer or
        <a href="/contact">drop us a line</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── HERO ─── */
  .journal-hero {
    background: var(--green-deep);
    color: var(--warm-cream);
    padding: clamp(140px, 16vw, 200px) var(--gutter) clamp(60px, 9vw, 110px);
    text-align: center;
  }

  .journal-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .journal-hero .eyebrow {
    color: var(--amber);
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .journal-hero h1 {
    font-size: clamp(46px, 6.5vw, 92px);
    line-height: 1.02;
    margin-bottom: 2rem;
  }

  .journal-hero h1 em {
    font-style: italic;
    color: var(--amber);
  }

  .hero-lede {
    font-size: clamp(16px, 1.7vw, 20px);
    line-height: 1.7;
    color: rgba(255, 241, 207, 0.78);
  }

  /* ─── FILTER ─── */
  .journal-filter {
    background: var(--cream);
    border-bottom: 1px solid rgba(19, 18, 16, 0.08);
    padding: 1.5rem var(--gutter);
  }

  .journal-filter-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .filter-list {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    padding: 0;
    margin: 0;
  }

  .filter-chip {
    background: transparent;
    border: 1px solid rgba(19, 18, 16, 0.14);
    color: rgba(19, 18, 16, 0.62);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 9px 18px;
    cursor: pointer;
    transition: all 0.2s var(--ease-smooth);
  }

  .filter-chip:hover {
    border-color: var(--brown);
    color: var(--brown);
  }

  .filter-chip.active {
    background: var(--green-deep);
    color: var(--cream);
    border-color: var(--green-deep);
  }

  /* ─── POSTS GRID ─── */
  .journal-grid-section {
    background: var(--cream);
    padding: clamp(60px, 9vw, 100px) var(--gutter);
  }

  .journal-grid-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .journal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .journal-card {
    background: var(--cream);
    transition-delay: var(--delay, 0ms);
  }

  .journal-card-link {
    display: block;
  }

  .journal-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
    margin-bottom: 1.25rem;
  }

  .journal-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-smooth);
  }

  .journal-card:hover .journal-card-image img {
    transform: scale(1.04);
  }

  .journal-card-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    background: rgba(19, 18, 16, 0.78);
    color: var(--warm-cream);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 6px 10px;
    backdrop-filter: blur(4px);
  }

  .journal-card-body {
    padding: 0 0.25rem;
  }

  .journal-card-cat {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brown);
    margin: 0 0 0.65rem;
  }

  .journal-card h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.18;
    margin: 0 0 0.85rem;
    color: var(--dark);
  }

  .journal-card-excerpt {
    font-size: 14.5px;
    line-height: 1.6;
    color: rgba(19, 18, 16, 0.72);
    margin: 0 0 1rem;
  }

  .journal-card-arrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--green-deep);
    border-bottom: 1px solid currentColor;
    padding-bottom: 3px;
    transition: color 0.2s var(--ease-smooth);
  }

  .journal-card:hover .journal-card-arrow {
    color: var(--brown);
  }

  .journal-empty-note {
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(15px, 1.5vw, 18px);
    color: rgba(19, 18, 16, 0.6);
    margin: 0;
  }

  .journal-empty-note a {
    color: var(--brown);
    border-bottom: 1px solid currentColor;
    margin-left: 0.25rem;
  }

  @media (max-width: 1000px) {
    .journal-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .journal-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Category filter
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('.journal-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter;
      chips.forEach((c) => c.classList.remove('active'));
      chip.classList.add('active');
      cards.forEach((card) => {
        if (!filter || filter === 'All' || card.dataset.category === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
