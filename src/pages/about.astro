---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Avela Travel | Nosara, Costa Rica Concierge"
  description="Avela Travel was built by people who live in Nosara. We know every villa, chef, boat captain, and trail — and we are here to make your trip extraordinary."
  image="/images/zenith/DSC04983-HDR.jpg"
>

  <!-- Page Header -->
  <div class="page-header">
    <div class="page-header-inner">
      <p class="eyebrow reveal">Our story</p>
      <h1 class="reveal reveal-delay-1">
        Built by people<br />
        <em>who live here</em>
      </h1>
    </div>
  </div>

  <!-- Intro -->
  <section class="section about-intro">
    <div class="section-inner about-intro-inner">
      <div class="about-intro-img reveal">
        <img
          src="/images/villas/raintree/01-view-sunset-infinity-pool.jpg"
          alt="Sunset view from a luxury villa's second-story infinity pool overlooking the jungle, Nosara, Costa Rica"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="about-intro-text reveal reveal-delay-2">
        <p class="eyebrow">Why Nosara</p>
        <h2>A place that changes the way you see time</h2>
        <p>
          Nosara sits inside Nicoya, one of the world's five Blue Zones — the rare places
          where people routinely live past 100, stay active and connected, and maintain
          a relationship with nature that most of the world has forgotten.
        </p>
        <p>
          It is not a resort town. There are no cruise ships, no chain hotels, no all-inclusive
          wristbands. What you find instead is a community of surfers, yogis, farmers, chefs,
          and expats who came for a week and never left. The food is extraordinary. The surf
          is consistent. The jungle is loud in the best way.
        </p>
        <p>
          Avela was built to give every guest access to that experience, fully and without
          the usual friction of trying to figure it out from scratch.
        </p>
      </div>
    </div>
  </section>

  <!-- The people behind Avela -->
  <section class="section team" id="team">
    <div class="section-inner">
      <div class="team-header reveal">
        <p class="eyebrow">Who we are</p>
        <h2>The people behind Avela</h2>
        <p class="team-lede">
          Avela began in 2025 — built by two people who have lived this place,
          worked in this place, and wanted to share it on their own terms. We
          host in English and Spanish, draw from years of hospitality experience,
          and answer every message ourselves.
        </p>
      </div>

      <div class="team-grid">
        <article class="team-card reveal">
          <div class="team-photo">
            <img
              src="/images/team/stacie-cofounder-avela-travel-nosara.jpg"
              alt="Stacie — co-founder of Avela Travel, Head of Hospitality, Nosara, Costa Rica"
              loading="lazy"
              decoding="async"
              width="600"
              height="800"
            />
          </div>
          <div class="team-body">
            <p class="eyebrow">Co-Founder · Head of Hospitality</p>
            <h3>Stacie</h3>
            <p class="team-bio">
              <em>Personal note from Stacie coming soon — the short why-she-built-Avela paragraph.</em>
            </p>
          </div>
        </article>

        <article class="team-card reveal reveal-delay-1">
          <div class="team-photo">
            <img
              src="/images/team/jordanny-cofounder-avela-travel-nosara.jpeg"
              alt="Jordanny — co-founder of Avela Travel, Adventures and Local Knowledge, Nosara, Costa Rica"
              loading="lazy"
              decoding="async"
              width="600"
              height="800"
            />
          </div>
          <div class="team-body">
            <p class="eyebrow">Co-Founder · Adventures &amp; Local Knowledge</p>
            <h3>Jordanny</h3>
            <p class="team-bio">
              <em>Personal note from Jordanny coming soon — the short why-he-built-Avela paragraph.</em>
            </p>
          </div>
        </article>
      </div>

      <div class="team-meta reveal reveal-delay-2">
        <div class="team-meta-item">
          <span class="team-meta-num">2025</span>
          <span class="team-meta-label">Founded</span>
        </div>
        <div class="team-meta-item">
          <span class="team-meta-num">EN / ES</span>
          <span class="team-meta-label">Languages</span>
        </div>
        <div class="team-meta-item">
          <span class="team-meta-num">Nosara</span>
          <span class="team-meta-label">On the ground</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section values" style="background: var(--sand);">
    <div class="section-inner">
      <div class="values-header reveal">
        <p class="eyebrow">How we work</p>
        <h2>Local knowledge, applied with care</h2>
      </div>
      <div class="values-grid">
        {[
          {
            num: '01',
            title: 'We only recommend what we know',
            body: 'Every villa on our list has been visited by our team. Every chef has cooked for us. We turn down partnerships when the quality is not right.',
          },
          {
            num: '02',
            title: 'Our interests are aligned with yours',
            body: 'We curate your entire trip — villa, chef, activities, transport — so our focus is always on making your experience as good as it can possibly be.',
          },
          {
            num: '03',
            title: 'We are here when things change',
            body: 'Concierge clients have a direct line to our team throughout their stay. Conditions shift, plans evolve, and requests come up at all hours. We handle it.',
          },
          {
            num: '04',
            title: 'We keep it honest',
            body: 'If a villa is booked or not right for your group, we will say so. We would rather help you find the perfect fit than push something that does not match.',
          },
        ].map(({ num, title, body }, i) => (
          <div class={`value-card reveal reveal-delay-${i + 1}`}>
            <span class="value-num">{num}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blue Zone -->
  <section class="section blue-zone">
    <div class="section-inner blue-zone-inner">
      <div class="blue-zone-text reveal">
        <p class="eyebrow">Blue Zone living</p>
        <h2>
          The Nicoya Peninsula is one of five places on earth where people live longest
        </h2>
        <p>
          Researchers studying longevity have identified five Blue Zones around the world.
          The Nicoya Peninsula, where Nosara sits, is one of them. The lifestyle here is
          active by default, social by nature, and grounded in whole food and unhurried time.
        </p>
        <p>
          Our wellness experiences are rooted in this tradition — morning yoga on hilltop
          platforms, sound healing in open-air studios, Blue Zone diet cooking classes,
          and spa treatments that use local plants and techniques.
        </p>
        <a href="/contact" class="btn-primary">Plan a Wellness Stay</a>
      </div>
      <div class="blue-zone-img reveal reveal-delay-2">
        <img
          src="/images/zenith/DSC04899-HDR.jpg"
          alt="Nosara hillside — Pacific views and jungle canopy"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Monkey Head Adventures -->
  <section class="section partner" style="background: var(--green-deep);">
    <div class="section-inner partner-inner">
      <div class="partner-text reveal">
        <p class="eyebrow">Our ocean partner</p>
        <h2>Monkey Head Adventures</h2>
        <p>
          Avela partners exclusively with Monkey Head Adventures for all ocean experiences.
          They own and operate two private boats based out of Nosara, crewed by people who
          have spent their lives on this stretch of the Pacific.
        </p>
        <p>
          Whether you are after world-class sportfishing, a snorkeling trip to the offshore
          rocks, or a sunset cruise with a bottle of local wine, Monkey Head runs it well.
          Their knowledge of conditions, marine life, and the best seasonal windows is second
          to none on the Nicoya coast.
        </p>
        <div class="partner-services">
          {['Sportfishing', 'Snorkeling', 'Sunset cruises', 'Whale watching (seasonal)', 'Dolphin tours'].map((s) => (
            <span class="partner-tag">{s}</span>
          ))}
        </div>
      </div>
      <div class="partner-img reveal reveal-delay-2">
        <img
          src="/images/zenith/DSC04830-HDR-Edit.jpg"
          alt="Pacific ocean from the Nosara coast"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section about-cta" style="background: var(--dark);">
    <div class="section-inner about-cta-inner reveal">
      <p class="eyebrow">Start the conversation</p>
      <h2>Tell us about your trip</h2>
      <p>
        We keep our planning calls short and our questions specific. Share your dates, group
        size, and what matters most — we will take care of the rest.
      </p>
      <div class="about-cta-actions">
        <a href="/contact" class="btn-primary">Plan My Trip</a>
        <a href="/villas" class="btn-ghost">Browse Villas</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Page Header */
  .page-header {
    background: var(--dark);
    padding: 160px var(--gutter) clamp(60px, 8vw, 100px);
  }

  .page-header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .page-header .eyebrow {
    margin-bottom: 1.25rem;
  }

  .page-header h1 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--warm-cream);
    line-height: 1.05;
  }

  .page-header h1 em {
    font-style: italic;
    color: var(--amber);
  }

  /* Intro */
  .about-intro-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
  }

  .about-intro-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .about-intro-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-intro-text .eyebrow {
    margin-bottom: 1.25rem;
  }

  .about-intro-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--green-deep);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .about-intro-text p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(19, 18, 16, 0.65);
    margin-bottom: 1rem;
  }

  /* The people behind Avela */
  .team {
    background: var(--cream);
  }
  .team-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 3.5rem;
  }
  .team-header h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--green-deep);
    margin: 1rem 0 1.25rem;
    line-height: 1.1;
  }
  .team-lede {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(19, 18, 16, 0.65);
  }
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  @media (max-width: 780px) {
    .team-grid { grid-template-columns: 1fr; gap: 3.5rem; }
  }
  .team-card {
    display: flex;
    flex-direction: column;
  }
  .team-photo {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--dark);
    margin-bottom: 1.5rem;
  }
  .team-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-smooth);
  }
  .team-card:hover .team-photo img {
    transform: scale(1.03);
  }
  .team-body .eyebrow {
    margin-bottom: 0.5rem;
  }
  .team-body h3 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    color: var(--green-deep);
    margin-bottom: 0.9rem;
    line-height: 1.1;
  }
  .team-bio {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(19, 18, 16, 0.72);
  }
  .team-bio em {
    font-style: italic;
    color: rgba(19, 18, 16, 0.4);
  }
  .team-meta {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(19, 18, 16, 0.1);
    flex-wrap: wrap;
  }
  .team-meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    text-align: center;
  }
  .team-meta-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 1;
    color: var(--green-deep);
  }
  .team-meta-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.5);
  }

  /* Values */
  .values-header {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .values-header .eyebrow {
    margin-bottom: 1rem;
  }

  .values-header h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--green-deep);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(58, 79, 65, 0.12);
  }

  .value-card {
    background: var(--sand);
    padding: clamp(2rem, 4vw, 3rem);
    border: 1px solid rgba(58, 79, 65, 0.08);
  }

  .value-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: rgba(58, 79, 65, 0.12);
    display: block;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .value-card h3 {
    font-size: 1.25rem;
    color: var(--green-deep);
    margin-bottom: 0.75rem;
  }

  .value-card p {
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(19, 18, 16, 0.6);
  }

  /* Blue Zone */
  .blue-zone-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
  }

  .blue-zone-text .eyebrow {
    margin-bottom: 1.25rem;
  }

  .blue-zone-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--green-deep);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .blue-zone-text p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(19, 18, 16, 0.65);
    margin-bottom: 1rem;
  }

  .blue-zone-text p:last-of-type {
    margin-bottom: 2rem;
  }

  .blue-zone-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .blue-zone-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Partner */
  .partner-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: center;
  }

  .partner-text .eyebrow {
    margin-bottom: 1.25rem;
  }

  .partner-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    color: var(--warm-cream);
    margin-bottom: 1.5rem;
  }

  .partner-text p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255, 241, 207, 0.55);
    margin-bottom: 1rem;
  }

  .partner-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .partner-tag {
    font-size: 12px;
    font-weight: 400;
    padding: 6px 14px;
    border: 1px solid rgba(255, 241, 207, 0.18);
    color: rgba(255, 241, 207, 0.65);
  }

  .partner-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .partner-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* CTA */
  .about-cta-inner {
    text-align: center;
  }

  .about-cta-inner .eyebrow {
    margin-bottom: 1rem;
  }

  .about-cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--warm-cream);
    margin-bottom: 1rem;
  }

  .about-cta-inner p {
    font-size: 16px;
    font-weight: 300;
    color: rgba(255, 241, 207, 0.55);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .about-cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 16px 36px;
    background: var(--amber);
    color: var(--cream);
    transition: background 0.3s;
  }

  .btn-primary:hover {
    background: var(--amber-deep);
  }

  .btn-ghost {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 15px 36px;
    border: 1px solid rgba(255, 241, 207, 0.3);
    color: rgba(255, 241, 207, 0.65);
    transition: all 0.3s;
  }

  .btn-ghost:hover {
    border-color: var(--warm-cream);
    color: var(--warm-cream);
  }

  @media (max-width: 768px) {
    .about-intro-inner,
    .blue-zone-inner,
    .partner-inner {
      grid-template-columns: 1fr;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
