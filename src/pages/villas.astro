<script>
  document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const galleryId = btn.dataset.gallery!;
      const src = btn.dataset.src!;
      const alt = btn.dataset.alt!;
      const mainImg = document.querySelector<HTMLImageElement>(`#${galleryId}-main .gallery-main-img`);
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = src;
          mainImg.alt = alt;
          mainImg.style.opacity = '1';
        }, 200);
      }
      document.querySelectorAll(`[data-gallery="${galleryId}"]`).forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>
