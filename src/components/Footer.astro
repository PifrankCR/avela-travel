---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" aria-label="Avela Travel — home">
        <img
          src="/images/avela-logo.png"
          alt="Avela Travel"
          class="footer-logo"
          width="100"
          height="46"
        />
      </a>
      <p class="footer-tagline">Blue Zone Spirit. Costa Rica Soul.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/villas">Luxury Villas</a></li>
          <li><a href="/#services">Private Chefs</a></li>
          <li><a href="/#services">Surf Sessions</a></li>
          <li><a href="/#services">Ocean Adventures</a></li>
          <li><a href="/#services">Jungle Adventures</a></li>
          <li><a href="/#services">Transport</a></li>
          <li><a href="/#services">Wellness</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About Avela</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/contact">Plan My Trip</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Connect</h4>
        <ul>
          <li>
            <a
              href="https://www.instagram.com/avelatravel"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Avela Travel on Instagram"
            >
              <span class="footer-ig-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="4.5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none" />
                </svg>
              </span>
              <span>@avelatravel</span>
            </a>
          </li>
        </ul>
        <p class="footer-sister-heading">Also in Nosara</p>
        <ul>
          <li>
            <a
              href="https://www.instagram.com/weddingsnosara"
              target="_blank"
              rel="noopener noreferrer"
            >
              Weddings Nosara
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/monkeyheadadventures"
              target="_blank"
              rel="noopener noreferrer"
            >
              Monkey Head Adventures
            </a>
          </li>
        </ul>
      </div>

      <div class="footer-col footer-newsletter">
        <h4>Stay Inspired</h4>
        <p>Trip ideas, Nosara guides, and seasonal availability, direct to your inbox.</p>
        <form class="newsletter-form" action="#" method="post">
          <input
            type="email"
            name="email"
            placeholder="Your email"
            required
            aria-label="Email address"
          />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Avela Travel. All rights reserved.</p>
    <p class="footer-bottom-links">
      <a href="/privacy">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <span>Nosara, Costa Rica</span>
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    color: rgba(251, 248, 242, 0.55);
    padding: clamp(60px, 8vw, 100px) var(--gutter) 0;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
    padding-bottom: clamp(60px, 8vw, 100px);
    border-bottom: 1px solid rgba(251, 248, 242, 0.07);
  }

  .footer-logo {
    height: 64px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer-tagline {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(251, 248, 242, 0.35);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .footer-col a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-ig-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
    color: var(--amber);
  }
  .footer-ig-icon svg {
    width: 100%;
    height: 100%;
  }
  .footer-sister-heading {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(251, 248, 242, 0.25);
    margin: 1.5rem 0 0.75rem;
  }

  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(251, 248, 242, 0.35);
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col a {
    font-size: 14px;
    color: rgba(251, 248, 242, 0.6);
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--warm-cream);
  }

  .footer-newsletter p {
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 1rem;
    color: rgba(251, 248, 242, 0.45);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .newsletter-form input {
    font-family: var(--font-body);
    font-size: 14px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--cream);
    outline: none;
    transition: border-color 0.2s;
  }

  .newsletter-form input::placeholder {
    color: rgba(251, 248, 242, 0.3);
  }

  .newsletter-form input:focus {
    border-color: var(--amber);
  }

  .newsletter-form button {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 11px 20px;
    background: var(--amber);
    color: var(--cream);
    transition: background 0.2s;
    align-self: flex-start;
  }

  .newsletter-form button:hover {
    background: var(--amber-deep);
  }

  .footer-bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    font-size: 12px;
    color: rgba(251, 248, 242, 0.25);
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom-links {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer-bottom-links a {
    color: rgba(251, 248, 242, 0.45);
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover {
    color: var(--warm-cream);
  }

  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
