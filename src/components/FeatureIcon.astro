    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 11a17 17 0 0 1 22 0" />
      <path d="M7 15a11 11 0 0 1 14 0" />
      <path d="M11 19a5 5 0 0 1 6 0" />
      <circle cx="14" cy="23" r="0.9" fill="currentColor" />
    </svg>
  )}
  {icon === 'ac' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 4v20M5 9l18 10M5 19l18-10" />
      <path d="M14 4l-2 3M14 4l2 3M14 24l-2-3M14 24l2-3" />
    </svg>
  )}
  {icon === 'solar' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="14" cy="14" r="4" />
      <path d="M14 3v3M14 22v3M3 14h3M22 14h3M6 6l2 2M20 20l2 2M22 6l-2 2M8 20l-2 2" />
    </svg>
  )}
  {icon === 'design' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 22L20 6" />
