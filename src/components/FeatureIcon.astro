  {icon === 'theater' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="5" width="22" height="14" rx="1.5" />
      <path d="M11 9l6 3-6 3z" />
      <path d="M9 23h10" />
      <path d="M14 19v4" />
    </svg>
  )}
  {icon === 'kitchen' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="5" y="3" width="18" height="22" rx="1.5" />
      <path d="M5 10h18" />
      <path d="M5 18h18" />
      <circle cx="9" cy="6.5" r="0.8" />
      <circle cx="13" cy="6.5" r="0.8" />
      <path d="M9 14h2M16 14h3" />
    </svg>
  )}
  {icon === 'sauna' && (
