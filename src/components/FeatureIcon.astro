---
// Picks a thin-line SVG icon based on a feature label keyword.
// All icons are 28×28, stroke-only, using currentColor so they pick up the parent's color (we set --amber in CSS).
interface Props {
  label: string;
}

const { label } = Astro.props;
const l = label.toLowerCase();

type IconKey =
  | 'pool'
  | 'jacuzzi'
  | 'ocean'
  | 'jungle'
  | 'beach'
  | 'gym'
  | 'theater'
  | 'kitchen'
  | 'sauna'
  | 'security'
  | 'wifi'
  | 'ac'
  | 'solar'
  | 'design'
  | 'elevator'
  | 'walking'
  | 'pin'
  | 'bbq'
  | 'glass'
  | 'levels'
  | 'bed'
  | 'star';

function pick(l: string): IconKey {
  if (l.includes('jacuzzi') || l.includes('plunge') || l.includes('hot tub')) return 'jacuzzi';
  if (l.includes('pool')) return 'pool';
  if (l.includes('ocean') || l.includes('sea') || l.includes('pacific')) return 'ocean';
  if (l.includes('jungle') || l.includes('reserve') || l.includes('jungle setting')) return 'jungle';
  if (l.includes('beach') || l.includes('playa') || l.includes('walking distance')) return 'walking';
  if (l.includes('gym') || l.includes('fitness')) return 'gym';
  if (l.includes('theater') || l.includes('cinema') || l.includes('movie')) return 'theater';
  if (l.includes('kitchen') || l.includes('chef')) return 'kitchen';
  if (l.includes('sauna') || l.includes('steam')) return 'sauna';
  if (l.includes('security') || l.includes('camera') || l.includes('guard')) return 'security';
  if (l.includes('wifi') || l.includes('internet')) return 'wifi';
  if (l.includes('air conditioning') || l.includes(' ac ') || l.endsWith(' ac') || l.startsWith('ac ')) return 'ac';
  if (l.includes('solar') || l.includes('sustainability') || l.includes('eco')) return 'solar';
  if (l.includes('design') || l.includes('architect') || l.includes('brutalist') || l.includes('modern')) return 'design';
  if (l.includes('elevator') || l.includes('lift')) return 'elevator';
  if (l.includes('bbq') || l.includes('grill') || l.includes('barbeque') || l.includes('barbecue')) return 'bbq';
  if (l.includes('glass') || l.includes('window') || l.includes('floor-to-ceiling')) return 'glass';
  if (l.includes('multi-level') || l.includes('multi level') || l.includes('three-floor') || l.includes('two-floor') || l.includes('story')) return 'levels';
  if (l.includes('suite') || l.includes('bed') || l.includes('king') || l.includes('queen')) return 'bed';
  if (l.includes('terrace') || l.includes('deck') || l.includes('balcony') || l.includes('patio')) return 'pin';
  if (l.includes('view')) return 'pin';
  return 'star';
}

const icon = pick(l);
---

<span class="feature-icon" aria-hidden="true">
  {icon === 'pool' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 19c2 0 2-1.5 4-1.5S9 19 11 19s2-1.5 4-1.5 2 1.5 4 1.5 2-1.5 4-1.5 2 1.5 2 1.5" />
      <path d="M3 23c2 0 2-1.5 4-1.5S9 23 11 23s2-1.5 4-1.5 2 1.5 4 1.5 2-1.5 4-1.5 2 1.5 2 1.5" />
      <path d="M8 17V8a3 3 0 0 1 3-3" />
      <path d="M20 17V8a3 3 0 0 0-3-3" />
      <path d="M8 11h12" />
    </svg>
  )}
  {icon === 'jacuzzi' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 14h22v6a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-6z" />
      <path d="M3 14V9a2 2 0 0 1 2-2h2" />
      <path d="M9 5c0 1 1 1 1 2s-1 1-1 2" />
