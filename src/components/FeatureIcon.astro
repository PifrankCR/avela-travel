      <rect x="6" y="3" width="16" height="22" rx="1.5" />
      <path d="M14 3v22" />
      <path d="M10 9l1.5-2 1.5 2M18 19l-1.5 2-1.5-2" />
    </svg>
  )}
  {icon === 'pin' && (
