      <path d="M3 22c2 0 2-1.5 4-1.5S9 22 11 22s2-1.5 4-1.5 2 1.5 4 1.5 2-1.5 4-1.5 2 1.5 2 1.5" />
    </svg>
  )}
  {icon === 'jungle' && (
    <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
