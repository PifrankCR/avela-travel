---
import BaseLayout from './BaseLayout.astro';

interface RelatedGuide {
  slug: string;
  title: string;
  category: string;
}

interface Props {
  title: string;
  description: string;
  category: string;
  readTime: string;
  heroImage?: string;
  heroImageAlt?: string;
  updated: string;
  pageSchema?: object;
  related?: RelatedGuide[];
}

const {
  title,
  description,
  category,
  readTime,
  heroImage,
  heroImageAlt,
  updated,
  pageSchema,
  related = [],
} = Astro.props;
---

<BaseLayout
  title={`${title} | Avela Travel Guides — Nosara, Costa Rica`}
  description={description}
  image={heroImage}
  schema={pageSchema}
>
  <article class="guide-article">
    <header class="guide-article-hero">
      <div class="guide-article-hero-inner">
        <p class="eyebrow">
          <a href="/guides">Guides</a> &nbsp;·&nbsp; <span>{category}</span>
        </p>
        <h1>{title}</h1>
        <p class="guide-article-lede">{description}</p>
        <p class="guide-article-meta">
          <span>{readTime}</span>
          <span aria-hidden="true">·</span>
          <span>Updated {updated}</span>
          <span aria-hidden="true">·</span>
          <span>By the Avela team in Nosara</span>
        </p>
      </div>
    </header>

    {heroImage && (
      <figure class="guide-article-figure">
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          loading="eager"
          decoding="async"
          width="1600"
          height="900"
        />
      </figure>
    )}

    <section class="guide-article-body">
      <div class="guide-article-body-inner">
        <slot />
      </div>
    </section>

    {related.length > 0 && (
      <section class="guide-related">
        <div class="guide-related-inner">
          <h2>Related guides</h2>
          <ul>
            {related.map((g) => (
              <li>
                <a href={`/guides/${g.slug}`}>
                  <span class="guide-related-cat">{g.category}</span>
                  <span class="guide-related-title">{g.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section class="guide-cta">
      <div class="guide-cta-inner">
        <p class="eyebrow">Plan your Nosara trip</p>
        <h2>Want this dialed in for you?</h2>
        <p>
          We live here. Tell us a few details and we will reply with a draft week shaped around your group, your dates, and the way you actually like to travel.
        </p>
        <a href="/contact" class="btn-primary">Start the conversation</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .guide-article-hero {
    background: var(--green-deep);
    color: var(--warm-cream);
    padding: clamp(120px, 14vw, 180px) var(--gutter) clamp(40px, 6vw, 70px);
  }

  .guide-article-hero-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .guide-article-hero .eyebrow {
    color: var(--amber);
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .guide-article-hero .eyebrow a {
    color: var(--amber);
    border-bottom: 1px solid currentColor;
  }

  .guide-article-hero h1 {
    font-size: clamp(38px, 5.5vw, 72px);
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .guide-article-lede {
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.6;
    color: rgba(255, 241, 207, 0.82);
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .guide-article-meta {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255, 241, 207, 0.55);
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .guide-article-figure {
    margin: 0;
    background: var(--cream);
  }

  .guide-article-figure img {
    width: 100%;
    max-width: 1400px;
    height: auto;
    display: block;
    margin: -40px auto 0;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .guide-article-body {
    background: var(--cream);
    padding: clamp(60px, 9vw, 100px) var(--gutter) clamp(40px, 6vw, 60px);
  }

  .guide-article-body-inner {
    max-width: 720px;
    margin: 0 auto;
    color: var(--dark);
  }

  .guide-article-body-inner :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 38px);
    line-height: 1.15;
    margin: 2.75rem 0 1rem;
    color: var(--dark);
  }

  .guide-article-body-inner :global(h2:first-child) {
    margin-top: 0;
  }

  .guide-article-body-inner :global(h3) {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 24px);
    line-height: 1.25;
    margin: 2rem 0 0.75rem;
    color: var(--dark);
  }

  .guide-article-body-inner :global(p) {
    font-size: 17px;
    line-height: 1.75;
    margin: 0 0 1.1rem;
    color: rgba(19, 18, 16, 0.86);
  }

  .guide-article-body-inner :global(ul),
  .guide-article-body-inner :global(ol) {
    margin: 0 0 1.4rem 1.25rem;
    padding: 0;
  }

  .guide-article-body-inner :global(li) {
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 0.55rem;
    color: rgba(19, 18, 16, 0.86);
  }

  .guide-article-body-inner :global(strong) {
    color: var(--dark);
    font-weight: 600;
  }

  .guide-article-body-inner :global(a) {
    color: var(--brown);
    border-bottom: 1px solid currentColor;
    transition: color 0.2s var(--ease-smooth);
  }

  .guide-article-body-inner :global(a:hover) {
    color: var(--amber-deep);
  }

  .guide-article-body-inner :global(.guide-callout) {
    background: rgba(184, 116, 42, 0.08);
    border-left: 3px solid var(--brown);
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    line-height: 1.6;
    color: var(--dark);
  }

  .guide-article-body-inner :global(.guide-callout p) {
    font-family: var(--font-display);
    font-style: italic;
    margin: 0;
    font-size: 17px;
  }

  .guide-article-body-inner :global(.guide-pull) {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.35;
    font-style: italic;
    color: var(--brown);
    margin: 2.25rem 0;
    padding-left: 1.25rem;
    border-left: 3px solid var(--amber);
  }

  .guide-article-body-inner :global(.guide-figure) {
    margin: 2.25rem 0;
  }

  .guide-article-body-inner :global(.guide-figure img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .guide-article-body-inner :global(.guide-figure figcaption) {
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(19, 18, 16, 0.5);
    margin-top: 0.6rem;
    text-align: center;
  }

  .guide-article-body-inner :global(.guide-faq) {
    border-top: 1px solid rgba(19, 18, 16, 0.1);
    margin-top: 2.5rem;
  }

  .guide-article-body-inner :global(.guide-faq details) {
    border-bottom: 1px solid rgba(19, 18, 16, 0.1);
    padding: 1.1rem 0;
  }

  .guide-article-body-inner :global(.guide-faq summary) {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.35;
    cursor: pointer;
    list-style: none;
    color: var(--dark);
    position: relative;
    padding-right: 2rem;
  }

  .guide-article-body-inner :global(.guide-faq summary::-webkit-details-marker) {
    display: none;
  }

  .guide-article-body-inner :global(.guide-faq summary::after) {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: 22px;
    color: var(--brown);
    transition: transform 0.2s var(--ease-smooth);
  }

  .guide-article-body-inner :global(.guide-faq details[open] summary::after) {
    content: '–';
  }

  .guide-article-body-inner :global(.guide-faq details p) {
    margin: 0.75rem 0 0;
    font-size: 16px;
  }

  .guide-related {
    background: var(--cream);
    border-top: 1px solid rgba(19, 18, 16, 0.08);
    padding: clamp(50px, 7vw, 80px) var(--gutter) clamp(30px, 5vw, 50px);
  }

  .guide-related-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .guide-related h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.6vw, 30px);
    margin: 0 0 1.5rem;
    color: var(--dark);
  }

  .guide-related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }

  .guide-related a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(19, 18, 16, 0.08);
    transition: background 0.2s var(--ease-smooth);
  }

  .guide-related a:hover .guide-related-title {
    color: var(--brown);
  }

  .guide-related-cat {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brown);
    flex-shrink: 0;
    min-width: 110px;
  }

  .guide-related-title {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--dark);
    transition: color 0.2s var(--ease-smooth);
  }

  .guide-cta {
    background: var(--green-deep);
    color: var(--warm-cream);
    padding: clamp(60px, 9vw, 100px) var(--gutter);
    text-align: center;
  }

  .guide-cta-inner {
    max-width: 620px;
    margin: 0 auto;
  }

  .guide-cta .eyebrow {
    color: var(--amber);
    margin-bottom: 1rem;
    display: inline-block;
  }

  .guide-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .guide-cta p {
    font-size: 17px;
    line-height: 1.65;
    color: rgba(255, 241, 207, 0.78);
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--amber);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 14px 28px;
    transition: background 0.2s var(--ease-smooth);
  }

  .btn-primary:hover {
    background: var(--amber-deep);
  }
</style>
